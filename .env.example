# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TRADES=crypto-trades
KAFKA_TOPIC_METRICS=crypto-metrics
KAFKA_GROUP_ID_PROCESSOR=processor-group
KAFKA_GROUP_ID_API=api-group

# ── API Server ─────────────────────────────────────────────────────────────
API_PORT=3001
WS_PORT=3001

# ── Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_PORT=8080

# ── Feeds (optional overrides) ────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com

# ── Analytics ─────────────────────────────────────────────────────────────
# Sliding window size for VWAP/SMA (number of trades)
SMA_WINDOW=20
# Z-score threshold above which a trade is flagged as anomalous
ANOMALY_ZSCORE_THRESHOLD=2.5

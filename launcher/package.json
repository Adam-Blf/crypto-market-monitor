{
  "name": "crypto-monitor-launcher",
  "version": "1.0.0",
  "description": "Standalone launcher for Crypto Market Monitor",
  "type": "module",
  "main": "src/index.mjs",
  "scripts": {
    "start": "node src/index.mjs",
    "build:win": "pkg src/index.mjs --target node20-win-x64 --output ../dist/crypto-monitor-win.exe --no-bytecode --public",
    "build:linux": "pkg src/index.mjs --target node20-linux-x64 --output ../dist/crypto-monitor-linux --no-bytecode --public",
    "build:mac": "pkg src/index.mjs --target node20-mac-x64 --output ../dist/crypto-monitor-mac --no-bytecode --public",
    "build:all": "npm run build:win && npm run build:linux && npm run build:mac"
  },
  "dependencies": {
    "open": "^10.1.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": ["../docker-compose.yml", "../.env.example"],
    "targets": ["node20-win-x64", "node20-linux-x64", "node20-mac-x64"]
  }
}
